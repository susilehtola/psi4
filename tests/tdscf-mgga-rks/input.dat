#! TDA and RPA excitation energies of water with meta-GGA functionals (RKS),
#! singlet and triplet, exercising the tau second-derivative kernel.
#! Reference values from PySCF 2.13.0 (same Libxc): 6-31G, identical geometry,
#! grids.atom_grid = (99, 590), SCF conv_tol 1e-12, TD conv_tol 1e-9.

# TPSS/6-31G, PySCF references
tpss_scf = -76.3878695612                                     #TEST
tpss_tda_singlet = [0.29126465, 0.37041879, 0.37135080]       #TEST
tpss_tda_triplet = [0.26459981, 0.32716251, 0.35075137]       #TEST
tpss_rpa_singlet = [0.29080605, 0.36745262, 0.37133166]       #TEST
# r2SCAN/6-31G, PySCF references
r2scan_scf = -76.3425594940                                   #TEST
r2scan_tda_singlet = [0.32327939, 0.39928493, 0.40959351]     #TEST

molecule h2o {
0 1
O  0.000  0.000  0.117
H  0.000  0.755 -0.469
H  0.000 -0.755 -0.469
symmetry c1
noreorient
}

set {
    reference rks
    basis 6-31G
    scf_type pk
    save_jk true
    dft_spherical_points 590
    dft_radial_points 99
    e_convergence 10
    d_convergence 9
}

from psi4.driver.procrouting.response.scf_response import tdscf_excitations

e, wfn = energy("TPSS", return_wfn=True)
compare_values(tpss_scf, e, 5, "TPSS SCF energy vs PySCF")                    #TEST

res = tdscf_excitations(wfn, states=3, tda=True, triplets="NONE", r_convergence=1e-7)
for i, ref in enumerate(sorted(tpss_tda_singlet)):                            #TEST
    compare_values(ref, sorted(r["EXCITATION ENERGY"] for r in res)[i], 5,    #TEST
                   f"TPSS TDA singlet root {i+1} vs PySCF")                   #TEST

res = tdscf_excitations(wfn, states=3, tda=True, triplets="ONLY", r_convergence=1e-7)
for i, ref in enumerate(sorted(tpss_tda_triplet)):                            #TEST
    compare_values(ref, sorted(r["EXCITATION ENERGY"] for r in res)[i], 5,    #TEST
                   f"TPSS TDA triplet root {i+1} vs PySCF")                   #TEST

res = tdscf_excitations(wfn, states=3, tda=False, triplets="NONE", r_convergence=1e-7)
for i, ref in enumerate(sorted(tpss_rpa_singlet)):                            #TEST
    compare_values(ref, sorted(r["EXCITATION ENERGY"] for r in res)[i], 5,    #TEST
                   f"TPSS RPA singlet root {i+1} vs PySCF")                   #TEST

clean()

e, wfn = energy("R2SCAN", return_wfn=True)
compare_values(r2scan_scf, e, 5, "r2SCAN SCF energy vs PySCF")                #TEST

res = tdscf_excitations(wfn, states=3, tda=True, triplets="NONE", r_convergence=1e-7)
for i, ref in enumerate(sorted(r2scan_tda_singlet)):                          #TEST
    compare_values(ref, sorted(r["EXCITATION ENERGY"] for r in res)[i], 5,    #TEST
                   f"r2SCAN TDA singlet root {i+1} vs PySCF")                 #TEST
